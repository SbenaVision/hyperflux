{
  "domain": "hiflux",
  "version": "1",
  "rules": [
    { "path": "hiflux.ui.app_title",           "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "HiFlux"}}],                        "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.nav_rules_label",     "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Rules"}}],                          "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.nav_legacy_label",    "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Legacy"}}],                         "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.search_placeholder",  "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Search rules..."}}],                "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.filter_status_label", "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Status"}}],                         "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.filter_source_label", "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Source"}}],                         "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.detail_panel_title",  "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Rule Detail"}}],                    "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.caption_size_label",  "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Caption"}}],                        "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.shortcuts_hint",      "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "n new · e edit · d delete · esc close"}}], "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.override_indicator",  "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "override"}}],                       "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.requires_label",      "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Requires"}}],                       "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.used_by_label",       "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Used by"}}],                        "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.cases_label",         "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Cases"}}],                          "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.output_type_label",   "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Output type"}}],                    "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.kind_label",          "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Kind"}}],                           "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.nav_lifecycle_label",       "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Lifecycle"}}],                  "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.path_label",                "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "path"}}],                      "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.source_label",              "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "source"}}],                    "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.status_label",              "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "status"}}],                    "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.dry_run_label",             "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Dry-run"}}],                   "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.lifecycle_header",          "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Lifecycle: delete"}}],         "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.lifecycle_addresses_label", "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Registered Addresses"}}],     "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.audit_log_label",           "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Audit Log"}}],                 "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.refresh_label",             "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Refresh"}}],                   "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.status_draft_label",        "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "draft"}}],                     "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.status_active_label",       "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "active"}}],                    "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.status_archived_label",     "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "archived"}}],                  "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.section_search",            "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Search results"}}],               "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.section_content",           "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Content"}}],                      "metadata": {"version": "1", "requires": [], "domain": "hiflux"} },
    { "path": "hiflux.ui.section_logic",             "kind": "compute", "inputs": [], "output": {"type": "string"}, "cases": [{"then": {"kind": "literal", "value": "Logic"}}],                        "metadata": {"version": "1", "requires": [], "domain": "hiflux"} }
  ]
}

    { "op": ">",   "arity": 2,   "input_types": ["number", "number"],        "output_type": "boolean" },
    { "op": ">=",  "arity": 2,   "input_types": ["number", "number"],        "output_type": "boolean" },
    { "op": "+",   "arity": 2,   "input_types": ["number", "number"],        "output_type": "number"  },
    { "op": "-",   "arity": 2,   "input_types": ["number", "number"],        "output_type": "number"  },
    { "op": "*",   "arity": 2,   "input_types": ["number", "number"],        "output_type": "number"  },

{
  "commands": [
    {
      "name": "validate",
      "aliases": ["check"],
      "description": "Validate all rule files. Exits 0 if all rules are valid.",
      "usage": "hf validate [--rules-dir <path>]",
      "options": [
        {
          "flag": "--rules-dir",
          "description": "Path to the rules directory (default: ./rules).",
          "type": "string",
          "default": "rules"
        }
      ],
      "args": []
    },
    {
      "name": "eval",
      "description": "Evaluate a rule against JSON inputs and print the result.",
      "usage": "hf eval <rulePath> --input '<json>' [--trace] [--rules-dir <path>]",
      "options": [
        {
          "flag": "--input",
          "short": "-i",
          "description": "JSON object of inputs for the rule (required).",
          "type": "string",
          "required": true
        },
        {
          "flag": "--trace",
          "short": "-t",
          "description": "Print the evaluation trace before the result.",
          "type": "boolean",
          "default": false
        },
        {
          "flag": "--rules-dir",
          "description": "Path to the rules directory (default: ./rules).",
          "type": "string",
          "default": "rules"
        }
      ],
      "args": [
        { "name": "rulePath", "description": "Fully-qualified rule path, e.g. pricing.atm.fee.", "required": true }
      ]
    },
    {
      "name": "lint",
      "aliases": ["check-code"],
      "description": "Run HyperFlux discipline enforcement against source and rule files.",
      "usage": "hf lint [--fix] [--format text|json]",
      "options": [
        {
          "flag": "--fix",
          "short": "-f",
          "description": "Apply unambiguous automated fixes.",
          "type": "boolean",
          "default": false
        },
        {
          "flag": "--format",
          "description": "Output format: text or json.",
          "type": "string",
          "default": "text"
        }
      ],
      "args": []
    },
    {
      "name": "test",
      "description": "Run snapshot tests for rules via Vitest.",
      "usage": "hf test [--watch]",
      "options": [
        {
          "flag": "--watch",
          "short": "-w",
          "description": "Watch rule files and re-run on change.",
          "type": "boolean",
          "default": false
        }
      ],
      "args": []
    },
    {
      "name": "trace",
      "description": "Trace a rule evaluation or render a saved trace JSON file.",
      "usage": "hf trace <rulePath> --input '<json>'  |  hf trace <file.json>",
      "options": [
        {
          "flag": "--input",
          "short": "-i",
          "description": "JSON inputs — evaluates the rule and shows its trace.",
          "type": "string"
        },
        {
          "flag": "--rules-dir",
          "description": "Path to the rules directory (default: ./rules).",
          "type": "string",
          "default": "rules"
        },
        {
          "flag": "--verbose",
          "short": "-v",
          "description": "Show full inputs and outputs for each node.",
          "type": "boolean",
          "default": false
        },
        {
          "flag": "--slow",
          "description": "Highlight nodes slower than this threshold (ms).",
          "type": "number",
          "default": 0
        },
        {
          "flag": "--depth",
          "description": "Maximum tree depth to render.",
          "type": "number",
          "default": 0
        }
      ],
      "args": [
        {
          "name": "file",
          "description": "Path to a trace JSON file saved by RequestContext.",
          "required": false
        }
      ]
    },
    {
      "name": "new",
      "description": "Scaffold a new rule stub in the given domain.",
      "usage": "hf new <domain> <name>",
      "options": [],
      "args": [
        { "name": "domain", "description": "Domain name (e.g. pricing).", "required": true },
        { "name": "name",   "description": "Rule name within the domain (e.g. atm.fee).", "required": true }
      ]
    },
    {
      "name": "init",
      "description": "Scaffold a new HyperFlux project in the current directory.",
      "usage": "hf init",
      "options": [],
      "args": []
    }
  ]
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "paths": {
      "@hyperflux/core": ["./packages/core/src/index.ts"],
      "@hyperflux/react": ["./packages/react/src/index.ts"],
      "@hyperflux/lint": ["./packages/lint/src/index.ts"],
      "@hyperflux/cli": ["./packages/cli/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "vitest.config.ts"
  ]
}

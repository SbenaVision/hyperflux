{
  "name": "hyperflux",
  "version": "0.1.0",
  "private": true,
  "description": "A typed rule engine that lets Claude apply 80% of product changes by editing rule rows instead of code.",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -b packages/core packages/react packages/lint packages/cli",
    "test": "vitest run",
    "lint:self": "node packages/cli/dist/index.js lint",
    "docs": "typedoc",
    "hf:check": "node scripts/hf-check.mjs",
    "hf:externalization-check": "node scripts/hf-externalization-check.mjs",
    "hf:data-validate": "node scripts/hf-data-validate.mjs",
    "hf:self-test": "node scripts/hf-check.mjs && node scripts/hf-externalization-check.mjs && node scripts/hf-data-validate.mjs && tsc --noEmit && vitest run"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "jsdom": "^29.1.1",
    "react-dom": "18",
    "typedoc": "^0.28.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
